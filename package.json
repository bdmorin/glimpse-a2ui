{
  "name": "a2glimpse",
  "version": "0.8.0",
  "description": "Mac-first A2UI v0.8 proof-of-concept appliance forked from Glimpse",
  "type": "module",
  "main": "src/a2glimpse.mjs",
  "exports": {
    ".": "./src/a2glimpse.mjs"
  },
  "bin": {
    "a2glimpse": "bin/a2glimpse.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:macos": "node scripts/build.mjs darwin",
    "build:app": "node scripts/build-app.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "test": "node test/test.mjs",
    "test:visual": "node test/visual.mjs",
    "test:visual:update": "node test/visual.mjs --update"
  },
  "files": [
    "src/a2glimpse.swift",
    "src/a2glimpse.mjs",
    "src/a2glimpse-host.html",
    "src/MaterialSymbolsOutlined.woff2",
    "src/follow-cursor-support.mjs",
    "bin/a2glimpse.mjs",
    "scripts/build.mjs",
    "scripts/postinstall.mjs",
    "README.md",
    "CHANGELOG.md",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "keywords": [
    "macos",
    "a2ui",
    "webview",
    "native",
    "ui",
    "webkit",
    "wkwebview",
    "swift",
    "gui",
    "agent",
    "dialog",
    "prompt",
    "overlay",
    "glimpse-fork"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bdmorin/glimpse-a2ui"
  },
  "author": "Brian Morin",
  "license": "MIT"
}
